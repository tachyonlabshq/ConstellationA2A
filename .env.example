# Constellation A2A - Environment Configuration
# Copy this file to .env and customize ALL values below before deploying.
# WARNING: Do NOT use these placeholder values in production.

# Conduit Matrix Server
# Generate with: openssl rand -hex 32
REGISTRATION_SECRET=GENERATE_A_RANDOM_SECRET_HERE

# Agent Credentials
# Generate unique passwords for each agent, e.g.: openssl rand -hex 16
COORDINATOR_PASSWORD=CHANGE_ME_coordinator
RESEARCHER_PASSWORD=CHANGE_ME_researcher
CODER_PASSWORD=CHANGE_ME_coder
